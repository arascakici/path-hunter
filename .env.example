# PathHunter — TESTNET ONLY configuration.
# Copy this file to `.env` and adjust. Never point this at mainnet.

# Horizon testnet endpoint + network passphrase.
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Scanner behaviour.
SCAN_INTERVAL_MS=10000      # delay between scan cycles (scan mode)
PROFIT_THRESHOLD_PCT=0.5    # minimum round-trip profit (%) to flag an opportunity
START_AMOUNT=100            # notional amount of the start asset used to simulate a cycle

# Asset list config file (see config/assets.example.json).
ASSETS_CONFIG=./config/assets.json

# --- Execute mode (TESTNET ONLY) -------------------------------------------
# Both the `--execute` CLI flag AND EXECUTE_ENABLED=true are required to submit.
EXECUTE_ENABLED=false
# A friendbot-funded testnet secret key (starts with S). Leave empty for scan mode.
# EXECUTE_SECRET_KEY=
