{
  "name": "path-hunter",
  "version": "0.1.0",
  "description": "PathHunter — a Stellar testnet triangular-arbitrage scanner bot with a React panel.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bot:scan": "tsx bot/cli.ts scan",
    "bot:execute": "tsx bot/cli.ts execute",
    "dev:api": "tsx scripts/dev-api.ts",
    "web": "vite web",
    "dev": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:api\" \"npm:web\"",
    "build:web": "vite build web",
    "preview:web": "vite preview web",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.1.0",
    "dotenv": "^16.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
